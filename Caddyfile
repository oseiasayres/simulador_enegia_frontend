# Servidor único: serve o SPA e faz proxy da API para o backend.
#
# HTTPS via Cloudflare (Origin Certificate + modo "Full (strict)"):
# a Cloudflare faz o proxy (WAF/DDoS/cache) e conecta no origin por HTTPS na :443,
# onde o Caddy apresenta o certificado de origin da Cloudflare (montado em /etc/caddy/certs).
# O Caddy redireciona :80 -> :443 automaticamente para os hostnames abaixo.
#
# Certificados (fora do Git, bind-mount pelo docker-compose):
#   /root/certs/origin.pem  e  /root/certs/origin.key
simulacaopropostasolar.com.br, www.simulacaopropostasolar.com.br {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

	encode gzip

	# API, docs e openapi vão para o backend
	@backend path /api/* /docs* /redoc* /openapi.json
	handle @backend {
		reverse_proxy backend:8000
	}

	# Frontend estático (SPA) — cai no index.html para rotas do client
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
